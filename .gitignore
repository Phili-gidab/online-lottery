# --- Dependencies & local toolchains -------------------------------------
node_modules/
vendor/
/tools/

# --- Environment & local data (never commit secrets or player PII) -------
.env
.env.*
!.env.example
*.sqlite
*.sqlite-journal
auth.json

# --- Frontend builds ------------------------------------------------------
.next/
out/
*.tsbuildinfo
next-env.d.ts

# --- Strapi (legacy backend) ----------------------------------------------
.tmp/
dist/
.strapi/
.strapi-updater.json

# --- Laravel public/ holds the deployed static export (generated by
#     deploy-frontend.ps1) — keep only Laravel's own entry files -----------
backend-php/public/*
!backend-php/public/index.php
!backend-php/public/.htaccess
!backend-php/public/robots.txt
starter/backend-php/public/*
!starter/backend-php/public/index.php
!starter/backend-php/public/.htaccess
!starter/backend-php/public/robots.txt

# --- Laravel runtime ------------------------------------------------------
storage/app/private/
storage/app/public/
storage/logs/
storage/framework/
storage/pail/
bootstrap/cache/*.php
.phpunit.result.cache

# --- Logs / OS noise -------------------------------------------------------
npm-debug.log*
yarn-error.log
Thumbs.db
.DS_Store
